{
  "name": "despacha-pr",
  "version": "1.0.0",
  "description": "Sistema de Gestão para Despachante de Veículos - Paraná",
  "main": "src/main/main.js",
  "author": "DespachaPR",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"wait-on http://localhost:3000 && electron .\"",
    "dev:renderer": "vite --port 3000",
    "build": "vite build && electron-builder",
    "build:win": "electron-builder --win",
    "db:init": "node scripts/init-db.js",
    "db:seed": "node scripts/seed.js"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "bcryptjs": "^2.4.3",
    "electron-store": "^8.1.0",
    "crypto-js": "^4.2.0",
    "xlsx": "^0.18.5",
    "pdfkit": "^0.14.0",
    "axios": "^1.6.7",
    "date-fns": "^3.3.1",
    "uuid": "^9.0.0",
    "node-cron": "^3.0.3",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.12.0",
    "vite": "^5.1.4",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "br.com.despachapr",
    "productName": "DespachaPR",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DespachaPR"
    },
    "extraResources": [
      {
        "from": "database/",
        "to": "database/"
      }
    ]
  }
}
